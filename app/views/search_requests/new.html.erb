<div class="page-shell">
  <section class="hero-card">
    <p class="eyebrow">Flight Fare Search</p>
    <h1>Plan your next trip</h1>
    <p class="hero-copy">Search airports by code, city, or localized name before starting the fare search.</p>
  </section>

  <section class="panel">
    <%= form_with url: search_requests_path, scope: :search_request, class: "search-form", data: { controller: "itinerary-builder" } do |form| %>
      <div class="form-grid">
        <div class="field">
          <%= form.label :trip_type, "Trip Type" %>
          <%= form.select :trip_type, [["One Way", "one_way"], ["Round Trip", "round_trip"], ["Multi City", "multi_city"]], { selected: @search_request.trip_type }, data: { action: "change->itinerary-builder#tripTypeChanged", itinerary_builder_target: "tripType" } %>
        </div>

        <div class="field airport-field" data-controller="airport-lookup" data-airport-lookup-endpoint-value="<%= airports_lookup_path(format: :json) %>" data-action="submit->airport-lookup#beforeSubmit">
          <%= label_tag :origin_airport_query, "Origin Airport" %>
          <%= text_field_tag :origin_airport_query, @search_request.origin_airport_code, autocomplete: "off", placeholder: "Search by airport code, city, or name", data: { airport_lookup_target: "input", action: "input->airport-lookup#inputChanged keydown->airport-lookup#keydown blur->airport-lookup#blur" }, role: "combobox", aria: { expanded: false, autocomplete: "list" } %>
          <%= form.hidden_field :origin_airport_code, value: @search_request.origin_airport_code, data: { airport_lookup_target: "hidden" } %>
          <p class="airport-lookup-status" data-airport-lookup-target="status"></p>
          <div class="airport-lookup-list is-hidden" data-airport-lookup-target="list" role="listbox"></div>
        </div>

        <div class="field airport-field" data-controller="airport-lookup" data-airport-lookup-endpoint-value="<%= airports_lookup_path(format: :json) %>" data-action="submit->airport-lookup#beforeSubmit">
          <%= label_tag :destination_airport_query, "Destination Airport" %>
          <%= text_field_tag :destination_airport_query, @search_request.destination_airport_code, autocomplete: "off", placeholder: "Search by airport code, city, or name", data: { airport_lookup_target: "input", action: "input->airport-lookup#inputChanged keydown->airport-lookup#keydown blur->airport-lookup#blur" }, role: "combobox", aria: { expanded: false, autocomplete: "list" } %>
          <%= form.hidden_field :destination_airport_code, value: @search_request.destination_airport_code, data: { airport_lookup_target: "hidden" } %>
          <p class="airport-lookup-status" data-airport-lookup-target="status"></p>
          <div class="airport-lookup-list is-hidden" data-airport-lookup-target="list" role="listbox"></div>
        </div>

        <div class="field checkbox-field">
          <%= form.label :direct_only do %>
            <%= form.check_box :direct_only, checked: @search_request.direct_only %>
            Direct flights only
          <% end %>
        </div>

        <div class="field">
          <%= form.label :departure_window_start_on, "Earliest Departure" %>
          <%= form.date_field :departure_window_start_on, required: true, value: @search_request.departure_window_start_on %>
        </div>

        <div class="field">
          <%= form.label :departure_window_end_on, "Latest Departure" %>
          <%= form.date_field :departure_window_end_on, required: true, value: @search_request.departure_window_end_on %>
        </div>

        <div class="field">
          <%= form.label :stay_length_days, "Trip Length (days)" %>
          <%= form.number_field :stay_length_days, min: 1, required: true, value: @search_request.stay_length_days, data: { action: "input->itinerary-builder#validate" } %>
        </div>

        <div class="field">
          <%= form.label :display_currency, "Display Currency" %>
          <%= form.select :display_currency, [["TWD", "TWD"], ["USD", "USD"], ["JPY", "JPY"]], { selected: @search_request.display_currency }, required: true %>
        </div>
      </div>

      <div class="validation-message" data-itinerary-builder-target="validation"></div>

      <section class="panel nested-panel is-hidden" data-itinerary-builder-target="legsSection">
        <div class="section-heading">
          <h2>Multi-city Legs</h2>
          <button type="button" class="secondary-button" data-action="itinerary-builder#addLeg">Add Leg</button>
        </div>
        <div class="legs-list" data-itinerary-builder-target="legsList"></div>
      </section>

      <template data-itinerary-builder-target="template">
        <div class="leg-row">
          <div class="field">
            <label>Leg Position</label>
            <input type="number" name="search_request[itinerary_legs][][position]" min="1" max="4" required>
          </div>
          <div class="field">
            <label>Origin Airport Code</label>
            <input type="text" name="search_request[itinerary_legs][][origin_airport_code]" placeholder="TPE" required>
          </div>
          <div class="field">
            <label>Destination Airport Code</label>
            <input type="text" name="search_request[itinerary_legs][][destination_airport_code]" placeholder="KIX" required>
          </div>
          <div class="field">
            <label>Departure Date</label>
            <input type="date" name="search_request[itinerary_legs][][departure_on]">
          </div>
        </div>
      </template>

      <div class="actions">
        <%= form.submit "Search Fares", class: "primary-button" %>
      </div>
    <% end %>
  </section>
</div>
