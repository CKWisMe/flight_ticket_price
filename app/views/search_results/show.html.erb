<div class="page-shell">
  <section class="panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Results</p>
        <h1>搜尋結果</h1>
      </div>
      <span class="<%= source_status_badge_class(@search_request.status) %>"><%= @search_request.status %></span>
    </div>

    <div class="recommendation-card">
      <h2>最優惠推薦</h2>
      <p><%= recommendation_message(@search_request.recommendation) %></p>
    </div>

    <%= form_with url: search_request_results_path(@search_request), method: :get, class: "sort-form" do |form| %>
      <%= form.label :sort, "排序方式" %>
      <%= form.select :sort, options_for_select(search_result_sort_options, @sort), {}, onchange: "this.form.requestSubmit()" %>
    <% end %>
  </section>

  <section class="panel">
    <div class="section-heading">
      <h2>來源狀態</h2>
    </div>
    <div class="status-list">
      <% @search_request.source_statuses.each do |status| %>
        <div class="status-card">
          <strong><%= status.source_key %></strong>
          <span class="<%= source_status_badge_class(status.status) %>"><%= status.status %></span>
          <% if status.error_message.present? %>
            <p><%= status.error_message %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="panel">
    <div class="section-heading">
      <h2>票價列表</h2>
      <p class="muted">價格與座位供應狀態可能隨售票來源變動。</p>
    </div>

    <% if @offers.empty? %>
      <div class="empty-state">
        <p>目前沒有符合條件的結果，請調整搜尋條件後再試一次。</p>
        <%= link_to "返回搜尋", root_path, class: "secondary-button" %>
      </div>
    <% else %>
      <div class="offer-list">
        <% @offers.each do |offer| %>
          <article class="offer-card">
            <header class="offer-card-header">
              <div>
                <p class="eyebrow"><%= offer.source_key %></p>
                <h3><%= offer.display_currency %> <%= offer.normalized_total_amount.to_f.round(2) %></h3>
              </div>
              <div class="offer-meta">
                <span><%= offer.original_currency %> <%= offer.total_amount.to_f.round(2) %></span>
                <span><%= offer.direct_flight ? "直飛" : "非直飛" %></span>
              </div>
            </header>

            <dl class="summary-grid">
              <div>
                <dt>去程</dt>
                <dd><%= l(offer.outbound_departure_at, format: :short) %> - <%= l(offer.outbound_arrival_at, format: :short) %></dd>
              </div>
              <% if offer.return_departure_at.present? %>
                <div>
                  <dt>回程</dt>
                  <dd><%= l(offer.return_departure_at, format: :short) %> - <%= l(offer.return_arrival_at, format: :short) %></dd>
                </div>
              <% end %>
              <div>
                <dt>總旅行時間</dt>
                <dd><%= offer.total_travel_minutes %> 分鐘</dd>
              </div>
              <div>
                <dt>抓取時間</dt>
                <dd><%= l(offer.fetched_at, format: :short) %></dd>
              </div>
            </dl>

            <ul class="disclosure-list">
              <li><%= offer.price_disclosure %></li>
              <li><%= offer.seat_availability_disclosure %></li>
              <li><%= offer.exchange_rate_disclosure %></li>
            </ul>

            <%= link_to "前往購買", offer.booking_url, class: "primary-button", target: "_blank", rel: "noreferrer noopener" %>
          </article>
        <% end %>
      </div>
    <% end %>
  </section>
</div>
